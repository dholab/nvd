params {
    // NVD v3 RESULTS DIRECTORY STRUCTURE
    // ********************************************************************************
    // Layout mirrors the pipeline flow: reads → assembly → classification → summary.
    // Each numbered directory corresponds to a pipeline stage. When multiple processes
    // contribute to a stage, each gets its own subdirectory within the stage folder.
    // ********************************************************************************
    nvd_results = params.results + "/nvd"

    // 01 — Virus-enriched reads from deacon filtering on raw input
    input_resolution = params.nvd_results + "/00_input_resolution"
    virus_enriched_reads = params.nvd_results + "/01_virus_enriched_reads"

    // 02 — Quality-filtered reads that went into SPAdes assembly
    quality_filtered_reads = params.nvd_results + "/02_quality_filtered_reads"

    // 03 — Raw SPAdes assembly output
    assembled_contigs = params.nvd_results + "/03_assembled_contigs"

    // 04 — Virus contig classification: deacon filter + read-back mapping
    virus_contig_classification = params.nvd_results + "/04_virus_contig_classification"

    // 05 — Megablast (fast BLAST pass)
    megablast_hits = params.nvd_results + "/05_megablast_hits"

    // 06 — BLASTn (sensitive BLAST pass)
    blastn_hits = params.nvd_results + "/06_blastn_hits"

    // 07 — Merged BLAST results with LCA and read counts
    merged_blast_results = params.nvd_results + "/07_merged_blast_results"

    // 08 — Concatenated all-sample summary (always produced)
    experiment_summary = params.nvd_results + "/08_experiment_summary"
    virus_enrichment_report = params.experiment_summary + "/virus_enrichment"

    // 09 — LabKey-formatted uploads (only when labkey=true)
    labkey_uploads = params.nvd_results + "/09_labkey_uploads"

    // Experimental — sourmash sketch-based analysis (only when experimental=true)
    experimental_sourmash = params.nvd_results + "/experimental_sourmash"
    // ********************************************************************************
}

// Assign the above paths to publish directories in processes throughout the pipeline
process {

    withName: 'RECORD_RUN_METADATA' {
        publishDir = [
            path: { params.results },
            mode: 'copy',
            overwrite: true,
            enabled: true
        ]
    }

    // =========================================================================
    // 00 — Resolved input declarations
    // =========================================================================
    withName: 'RESOLVE_READ_INPUTS' {
        publishDir = [
            path: { params.input_resolution },
            mode: 'copy',
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename },
            enabled: true
        ]
    }

    // =========================================================================
    // 01 — Virus-enriched reads
    // =========================================================================
    withName: 'DEACON_ENRICH_TARGET_READS' {
        publishDir = [
            path: { params.virus_enriched_reads },
            mode: 'copy',
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename },
            enabled: { NvdUtils.targetEnrichmentEnabled(params) }
        ]
    }

    // =========================================================================
    // 02 — Quality-filtered reads (final preprocessing output)
    // =========================================================================
    withName: 'REPAIR_PAIRS' {
        publishDir = [
            path: { params.quality_filtered_reads },
            mode: 'copy',
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename },
            enabled: true
        ]
    }

    withName: 'SOURMASH_SKETCH_QUERY_METAGENOME' {
        publishDir = [
            path: { params.experimental_sourmash + "/query_sketches" },
            mode: 'copy',
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename },
            enabled: params.experimental == true
        ]
    }

    withName: 'SOURMASH_FETCH_REF_SKETCH' {
        publishDir = [
            path: { params.experimental_sourmash + "/reference_profiling/reference" },
            mode: 'copy',
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename },
            enabled: false
        ]
    }

    withName: 'SOURMASH_SKETCH_REF_FASTA' {
        publishDir = [
            path: { params.experimental_sourmash + "/reference_profiling/reference" },
            mode: 'copy',
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename },
            enabled: false
        ]
    }

    withName: 'SOURMASH_GATHER_QUERY_METAGENOME' {
        publishDir = [
            path: { params.experimental_sourmash + "/reference_profiling/gather" },
            mode: 'copy',
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename },
            enabled: params.experimental == true
        ]
    }

    withName: 'SOURMASH_FETCH_LINEAGES' {
        publishDir = [
            path: { params.experimental_sourmash + "/reference_profiling/taxonomy" },
            mode: 'copy',
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename },
            enabled: false
        ]
    }

    withName: 'SOURMASH_STAGE_REFERENCE' {
        publishDir = [
            path: { params.experimental_sourmash + "/reference_profiling/reference" },
            mode: 'copy',
            enabled: params.experimental == true
        ]
    }

    withName: 'SOURMASH_TAX_METAGENOME' {
        publishDir = [
            path: { params.experimental_sourmash + "/reference_profiling/taxonomy" },
            mode: 'copy',
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename },
            enabled: params.experimental == true
        ]
    }

    withName: 'RENDER_TAXON_ABUNDANCE_SUNBURST' {
        publishDir = [
            path: { params.experimental_sourmash + "/reference_profiling/reports/taxburst/per_sample" },
            mode: 'copy',
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename },
            enabled: params.experimental == true
        ]
    }

    withName: 'RENDER_MERGED_TAXON_ABUNDANCE_SUNBURST' {
        publishDir = [
            path: { params.experimental_sourmash + "/reference_profiling/reports/taxburst" },
            mode: 'copy',
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename },
            enabled: params.experimental == true
        ]
    }

    withName: 'RENDER_SOURMASH_SANKEY' {
        publishDir = [
            path: { params.experimental_sourmash + "/reference_profiling/reports/sankey" },
            mode: 'copy',
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename },
            enabled: params.experimental == true
        ]
    }

    withName: 'SOURMASH_COLLECT_QUERY_SKETCHES' {
        publishDir = [
            path: { params.experimental_sourmash + "/sample_similarity_qc/sketch_collection" },
            mode: 'copy',
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename },
            enabled: params.experimental == true
        ]
    }

    withName: 'SOURMASH_COMPARE_QUERY_SKETCHES' {
        publishDir = [
            path: { params.experimental_sourmash + "/sample_similarity_qc/similarity_matrices" },
            mode: 'copy',
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename },
            enabled: params.experimental == true
        ]
    }

    withName: 'COMPUTE_SAMPLE_SKETCH_DISTANCES' {
        publishDir = [
            path: { params.experimental_sourmash + "/sample_similarity_qc/pairwise_distances" },
            mode: 'copy',
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename },
            enabled: params.experimental == true
        ]
    }

    withName: 'COMPUTE_SAMPLE_ORDINATION' {
        publishDir = [
            path: { params.experimental_sourmash + "/sample_similarity_qc/ordination" },
            mode: 'copy',
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename },
            enabled: params.experimental == true
        ]
    }

    withName: 'REPORT_POSSIBLE_SAMPLE_MIXUPS' {
        publishDir = [
            path: { params.experimental_sourmash + "/sample_similarity_qc/possible_mixups" },
            mode: 'copy',
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename },
            enabled: params.experimental == true
        ]
    }

    withName: 'SUMMARIZE_SAMPLE_SIMILARITY' {
        publishDir = [
            path: { params.experimental_sourmash + "/sample_similarity_qc/possible_mixups" },
            mode: 'copy',
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename },
            enabled: params.experimental == true
        ]
    }

    withName: 'PLOT_SAMPLE_ORDINATION' {
        publishDir = [
            path: { params.experimental_sourmash + "/sample_similarity_qc/plots" },
            mode: 'copy',
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename },
            enabled: params.experimental == true
        ]
    }

    // =========================================================================
    // 03 — Assembled contigs
    // =========================================================================
    withName: 'RUN_SPADES' {
        publishDir = [
            path: { params.assembled_contigs },
            mode: 'copy',
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename },
            enabled: true
        ]
    }

    // =========================================================================
    // 04 — Virus contig classification
    // =========================================================================
    withName: 'DEACON_FILTER_CONTIGS' {
        publishDir = [
            path: { params.virus_contig_classification + "/filtered_contigs" },
            mode: 'copy',
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename },
            enabled: true
        ]
    }

    withName: 'MAP_READS_TO_CONTIGS' {
        publishDir = [
            path: { params.virus_contig_classification + "/read_alignments" },
            mode: 'copy',
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename },
            enabled: true
        ]
    }

    withName: 'COUNT_MAPPED_READS' {
        publishDir = [
            path: { params.virus_contig_classification + "/contig_read_counts" },
            mode: 'copy',
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename },
            enabled: true
        ]
    }

    // =========================================================================
    // 05 — Megablast hits (fast BLAST pass)
    // =========================================================================
    withName: 'ANNOTATE_MEGABLAST_RESULTS' {
        publishDir = [
            path: { params.megablast_hits + "/annotated" },
            mode: 'copy',
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename },
            enabled: true
        ]
    }

    withName: 'FILTER_NON_VIRUS_MEGABLAST_NODES' {
        publishDir = [
            path: { params.megablast_hits + "/virus_only" },
            mode: 'copy',
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename },
            enabled: true
        ]
    }

    withName: 'REMOVE_MEGABLAST_MAPPED_CONTIGS' {
        publishDir = [
            path: { params.megablast_hits + "/unclassified_contigs" },
            mode: 'copy',
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename },
            enabled: true
        ]
    }

    // =========================================================================
    // 06 — BLASTn hits (sensitive BLAST pass)
    // =========================================================================
    withName: 'ANNOTATE_BLASTN_RESULTS' {
        publishDir = [
            path: { params.blastn_hits + "/annotated" },
            mode: 'copy',
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename },
            enabled: true
        ]
    }

    withName: 'FILTER_NON_VIRUS_BLASTN_NODES' {
        publishDir = [
            path: { params.blastn_hits + "/virus_only" },
            mode: 'copy',
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename },
            enabled: true
        ]
    }

    // =========================================================================
    // 07 — Merged BLAST results
    // =========================================================================
    withName: 'MERGE_FILTERED_BLAST_RESULTS' {
        publishDir = [
            path: { params.merged_blast_results + "/merged" },
            mode: 'copy',
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename },
            enabled: true
        ]
    }

    withName: 'ANNOTATE_LEAST_COMMON_ANCESTORS' {
        publishDir = [
            path: { params.merged_blast_results + "/lca_annotated" },
            mode: 'copy',
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename },
            enabled: true
        ]
    }

    withName: 'ADD_READ_COUNTS_TO_BLAST' {
        publishDir = [
            path: { params.merged_blast_results + "/final" },
            mode: 'copy',
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename },
            enabled: true
        ]
    }

    // =========================================================================
    // 08 — Experiment summary (concatenated all-sample BLAST)
    // =========================================================================
    withName: 'CONCATENATE_EXPERIMENT_BLAST' {
        publishDir = [
            path: { params.experiment_summary },
            mode: 'copy',
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename },
            enabled: true
        ]
    }

    withName: 'VIRUS_ENRICHMENT_REPORT' {
        publishDir = [
            path: { params.virus_enrichment_report },
            mode: 'copy',
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename },
            enabled: true
        ]
    }

    // =========================================================================
    // 09 — LabKey uploads (only populated when labkey=true)
    // =========================================================================
    withName: 'LABKEY_PREPARE_BLAST' {
        publishDir = [
            path: { params.labkey_uploads + "/prepared_blast" },
            mode: 'copy',
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename },
            enabled: true
        ]
    }

    withName: 'LABKEY_PREPARE_FASTA' {
        publishDir = [
            path: { params.labkey_uploads + "/prepared_fasta" },
            mode: 'copy',
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename },
            enabled: true
        ]
    }

    withName: 'LABKEY_UPLOAD_BLAST' {
        publishDir = [
            path: { params.labkey_uploads + "/upload_logs" },
            mode: 'copy',
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename },
            enabled: true
        ]
    }

    withName: 'LABKEY_UPLOAD_FASTA' {
        publishDir = [
            path: { params.labkey_uploads + "/upload_logs" },
            mode: 'copy',
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename },
            enabled: true
        ]
    }

    withName: 'LABKEY_CONCAT_ALL_SAMPLE_BLAST_RESULTS' {
        publishDir = [
            path: { params.labkey_uploads + "/concatenated" },
            mode: 'copy',
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename },
            enabled: true
        ]
    }

}
