params {
    // NVD v3 RESULTS DIRECTORY STRUCTURE
    // ********************************************************************************
    // Numbers provide stable display order and broadly follow pipeline progression.
    // Later directories group important result families rather than individual stages.
    // ********************************************************************************
    nvd_results = params.results + "/nvd"

    // 00 — Resolved input declarations
    input_resolution = params.nvd_results + "/00_input_resolution"
    raw_fastqc = params.input_resolution + "/fastqc"

    // 01 — Target enrichment reads, summaries, and plots
    target_enriched_reads = params.nvd_results + "/01_target_enrichment/reads"
    target_enrichment_summaries = params.nvd_results + "/01_target_enrichment/summaries"
    target_enrichment_plots = params.nvd_results + "/01_target_enrichment/plots"

    // 02 — Final preprocessed reads that went into de novo assembly
    preprocessed_reads = params.nvd_results + "/02_preprocessed_reads"

    // 03 — De novo assembly output
    assembled_contigs = params.nvd_results + "/03_assembled_contigs"

    // 04 — Target query preparation: contig filtering, mapback, and query batching
    target_query_preparation = params.nvd_results + "/04_target_query_preparation"

    // 05 — Megablast (fast BLAST pass)
    megablast_hits = params.nvd_results + "/05_megablast_hits"

    // 06 — BLASTn (sensitive BLAST pass)
    blastn_hits = params.nvd_results + "/06_blastn_hits"

    // 07 — Merged BLAST results with LCA and read counts
    merged_blast_results = params.nvd_results + "/07_merged_blast_results"

    // 08 — Metagenomic profiles grouped by profiling capability and engine
    crumbs_profiles = params.nvd_results + "/08_metagenomic_profiles/crumbs"
    rapid_screening = params.nvd_results + "/08_metagenomic_profiles/rapid_screening"
    sourmash_screening_engine = params.rapid_screening + "/engines/sourmash"

    // 09 — Sample similarity and possible-mixup quality control
    sample_similarity_qc = params.nvd_results + "/09_sample_similarity_qc"

    // 10 — Rapid-screening evaluation artifacts
    rapid_screening_eval = params.nvd_results + "/10_rapid_screening_eval"

    // 11 — Query-level, taxon-level, per-sample, and all-sample Big Tables
    big_tables = params.nvd_results + "/11_big_tables"

    // 12 — Standalone experiment-wide summaries
    experiment_summary = params.nvd_results + "/12_experiment_summary"

    // 13 — LabKey-formatted uploads (only when labkey=true)
    labkey_uploads = params.nvd_results + "/13_labkey_uploads"
    // ********************************************************************************
}

// Assign the above paths to publish directories in processes throughout the pipeline
process {

    withName: 'RECORD_RUN_METADATA' {
        publishDir = [
            path: { params.results },
            mode: 'copy',
            overwrite: true,
            enabled: true
        ]
    }

    // =========================================================================
    // 00 — Resolved input declarations
    // =========================================================================
    withName: 'RESOLVE_READ_INPUTS' {
        publishDir = [
            path: { params.input_resolution },
            mode: 'copy',
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename },
            enabled: true
        ]
    }

    withName: 'FASTQC_RAW' {
        publishDir = [
            path: { params.raw_fastqc },
            mode: 'copy',
            pattern: '*_fastqc.{zip,html}',
            enabled: true
        ]
    }

    withName: 'MULTIQC_NVD' {
        publishDir = [
            path: { params.nvd_results },
            mode: 'copy',
            enabled: true
        ]
    }

    // =========================================================================
    // 01 — Target-enriched reads
    // =========================================================================
    withName: 'DEACON_ENRICH_TARGET_READS' {
        publishDir = [
            [
                path: { params.target_enriched_reads },
                mode: 'copy',
                pattern: '*.fastq.gz',
                enabled: !params.no_enrichment && (params.virus_index || params.virus_index_url || params.virus_reference_fasta)
            ],
            [
                path: { params.target_enrichment_summaries },
                mode: 'copy',
                pattern: '*.json',
                enabled: !params.no_enrichment && (params.virus_index || params.virus_index_url || params.virus_reference_fasta)
            ]
        ]
    }

    // =========================================================================
    // 02 — Preprocessed reads (final preprocessing output)
    // =========================================================================
    withName: 'PROFILE_READS' {
        publishDir = [
            path: { params.preprocessed_reads },
            mode: 'copy',
            pattern: 'publish/*',
            saveAs: { filename ->
                def name = filename.tokenize('/').last()
                if (name.endsWith('.fastx_profile.json') || name.endsWith('_histogram.tsv')) {
                    return "profiles/${name}"
                }
                return name
            },
            enabled: true
        ]
    }

    withName: 'PLOT_READ_LENGTH_PROFILES' {
        publishDir = [
            path: { params.preprocessed_reads + "/plots" },
            mode: 'copy',
            enabled: true
        ]
    }

    withName: 'PLOT_READ_QUALITY_PROFILES' {
        publishDir = [
            path: { params.preprocessed_reads + "/plots" },
            mode: 'copy',
            enabled: true
        ]
    }

    // =========================================================================
    // 08 — Sourmash metagenomic profiles
    // =========================================================================
    withName: 'SOURMASH_SKETCH_QUERY_METAGENOME' {
        publishDir = [
            path: { params.sourmash_screening_engine + "/query_sketches" },
            mode: 'copy',
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename },
            enabled: params.experimental == true
        ]
    }

    withName: 'SOURMASH_STAGE_REFERENCE' {
        publishDir = [
            path: { params.sourmash_screening_engine + "/reference" },
            mode: 'copy',
            enabled: params.experimental == true
        ]
    }

    withName: 'SOURMASH_GATHER_QUERY_METAGENOME' {
        publishDir = [
            path: { params.sourmash_screening_engine + "/gather" },
            mode: 'copy',
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename },
            enabled: params.experimental == true
        ]
    }

    withName: 'SOURMASH_TAX_METAGENOME' {
        publishDir = [
            path: { params.sourmash_screening_engine + "/taxonomy" },
            mode: 'copy',
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename },
            enabled: params.experimental == true
        ]
    }

    withName: 'ANNOTATE_SOURMASH_RISK_GROUPS' {
        publishDir = [
            path: { params.sourmash_screening_engine + "/taxonomy/risk_groups" },
            mode: 'copy',
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename },
            enabled: params.experimental == true
        ]
    }

    withName: 'RENDER_TAXON_ABUNDANCE_SUNBURST' {
        publishDir = [
            path: { params.sourmash_screening_engine + "/plots/taxburst/per_sample" },
            mode: 'copy',
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename },
            enabled: params.experimental == true
        ]
    }

    withName: 'RENDER_MERGED_TAXON_ABUNDANCE_SUNBURST' {
        publishDir = [
            path: { params.sourmash_screening_engine + "/plots/taxburst" },
            mode: 'copy',
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename },
            enabled: params.experimental == true
        ]
    }

    withName: 'RENDER_SOURMASH_SANKEY' {
        publishDir = [
            path: { params.sourmash_screening_engine + "/plots/sankey" },
            mode: 'copy',
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename },
            enabled: params.experimental == true
        ]
    }

    // =========================================================================
    // 09 — Sample similarity quality control
    // =========================================================================
    withName: 'SOURMASH_COLLECT_QUERY_SKETCHES' {
        publishDir = [
            path: { params.sample_similarity_qc + "/sketch_collection" },
            mode: 'copy',
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename },
            enabled: params.experimental == true
        ]
    }

    withName: 'SOURMASH_COMPARE_QUERY_SKETCHES' {
        publishDir = [
            path: { params.sample_similarity_qc + "/similarity_matrices" },
            mode: 'copy',
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename },
            enabled: params.experimental == true
        ]
    }

    withName: 'COMPUTE_SAMPLE_SKETCH_DISTANCES' {
        publishDir = [
            path: { params.sample_similarity_qc + "/pairwise_distances" },
            mode: 'copy',
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename },
            enabled: params.experimental == true
        ]
    }

    withName: 'COMPUTE_SAMPLE_ORDINATION' {
        publishDir = [
            path: { params.sample_similarity_qc + "/ordination" },
            mode: 'copy',
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename },
            enabled: params.experimental == true
        ]
    }

    withName: 'REPORT_POSSIBLE_SAMPLE_MIXUPS' {
        publishDir = [
            path: { params.sample_similarity_qc + "/possible_mixups" },
            mode: 'copy',
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename },
            enabled: params.experimental == true
        ]
    }

    withName: 'SUMMARIZE_SAMPLE_SIMILARITY' {
        publishDir = [
            path: { params.sample_similarity_qc + "/possible_mixups" },
            mode: 'copy',
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename },
            enabled: params.experimental == true
        ]
    }

    withName: 'PLOT_SAMPLE_ORDINATION' {
        publishDir = [
            path: { params.sample_similarity_qc + "/plots" },
            mode: 'copy',
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename },
            enabled: params.experimental == true
        ]
    }

    // =========================================================================
    // 10 — Rapid-screening evaluation
    // =========================================================================
    withName: 'BUILD_RAPID_SCREENING_EVAL_DB' {
        publishDir = [
            path: { params.rapid_screening_eval },
            mode: 'copy',
            saveAs: { filename ->
                if (filename.equals('versions.yml')) {
                    return null
                }
                def name = filename.tokenize('/').last()
                if (name.endsWith('.duckdb')) {
                    return "database/${name}"
                }
                if (name.endsWith('.tsv')) {
                    return "exports/${name}"
                }
                return name
            },
            enabled: params.experimental == true
        ]
    }

    withName: 'RENDER_RAPID_SCREENING_EVAL' {
        publishDir = [
            path: { params.rapid_screening_eval + "/reports" },
            mode: 'copy',
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename },
            enabled: params.experimental == true
        ]
    }

    // =========================================================================
    // 03 — Assembled contigs
    // =========================================================================
    withName: 'ASSEMBLE_WITH_SPADES' {
        publishDir = [
            path: { params.assembled_contigs + "/spades" },
            mode: 'copy',
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename },
            enabled: true
        ]
    }

    withName: 'ASSEMBLE_WITH_MYLOASM' {
        publishDir = [
            path: { params.assembled_contigs + "/myloasm" },
            mode: 'copy',
            enabled: params.experimental == true
        ]
    }

    withName: 'ASSEMBLE_WITH_METAMDBG' {
        publishDir = [
            path: { params.assembled_contigs + "/metamdbg" },
            mode: 'copy',
            enabled: params.experimental == true
        ]
    }

    withName: 'ASSEMBLE_WITH_METAFLYE' {
        publishDir = [
            path: { params.assembled_contigs + "/metaflye" },
            mode: 'copy',
            enabled: params.experimental == true
        ]
    }

    withName: 'REPORT_LONG_READ_ASSEMBLY_ELIGIBILITY' {
        publishDir = [
            path: { params.assembled_contigs + "/decisions" },
            mode: 'copy',
            enabled: params.experimental == true
        ]
    }

    withName: 'EXTRACT_UNIQUE_CONTIGS' {
        publishDir = [
            path: { params.assembled_contigs + "/long_read_union" },
            mode: 'copy',
            enabled: params.experimental == true
        ]
    }

    // =========================================================================
    // 04 — Target query preparation
    // =========================================================================
    withName: 'PROFILE_FILTERED_CONTIGS' {
        publishDir = [
            path: { params.target_query_preparation + "/filtered_contigs" },
            mode: 'copy',
            pattern: 'publish/*',
            saveAs: { filename ->
                def name = filename.tokenize('/').last()
                if (name.endsWith('.fastx_profile.json') || name.endsWith('_histogram.tsv')) {
                    return "profiles/${name}"
                }
                return name
            },
            enabled: true
        ]
    }

    withName: 'DEACON_FILTER_CONTIGS' {
        publishDir = [
            path: { params.target_query_preparation + "/decisions" },
            mode: 'copy',
            pattern: '*.contig_target_filtering.tsv',
            enabled: true
        ]
    }

    withName: 'PLOT_FILTERED_CONTIG_LENGTH_PROFILES' {
        publishDir = [
            path: { params.target_query_preparation + "/filtered_contigs/plots" },
            mode: 'copy',
            enabled: true
        ]
    }

    withName: 'MAP_PAIRED_READS' {
        publishDir = [
            [
                path: { params.target_query_preparation + "/read_alignments" },
                mode: 'copy',
                pattern: '*.{bam,bai}',
                enabled: true
            ],
            [
                path: { params.target_query_preparation + "/mapback_unmapped_reads" },
                mode: 'copy',
                pattern: '*.mapback_unmapped.fastq.gz',
                enabled: params.experimental == true
            ],
            [
                path: { params.target_query_preparation + "/decisions" },
                mode: 'copy',
                pattern: '*.mapback_unmapped_counts.tsv',
                enabled: params.experimental == true
            ]
        ]
    }

    withName: 'MAP_SINGLE_READS' {
        publishDir = [
            path: { params.target_query_preparation + "/read_alignments" },
            mode: 'copy',
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename },
            enabled: true
        ]
    }

    withName: 'COUNT_MAPPED_READS' {
        publishDir = [
            [
                path: { params.target_query_preparation + "/read_alignments" },
                mode: 'copy',
                pattern: '*.{bam,bai}',
                enabled: true
            ],
            [
                path: { params.target_query_preparation + "/contig_read_counts" },
                mode: 'copy',
                pattern: '*_mapped_counts.txt',
                enabled: true
            ]
        ]
    }

    withName: 'RENDER_CONTIG_COVERAGE_HISTOGRAM' {
        publishDir = [
            path: { params.target_query_preparation + "/contig_coverage" },
            mode: 'copy',
            enabled: true
        ]
    }

    withName: 'RENDER_CONTIG_ALIGNMENT_PLOTS' {
        publishDir = [
            path: { params.target_query_preparation + "/contig_alignment_plots" },
            mode: 'copy',
            enabled: true
        ]
    }

    withName: 'EXTRACT_UNMAPPED_READS' {
        publishDir = [
            [
                path: { params.target_query_preparation + "/mapback_unmapped_reads" },
                mode: 'copy',
                pattern: '*.fastq.gz',
                enabled: params.experimental == true
            ],
            [
                path: { params.target_query_preparation + "/decisions" },
                mode: 'copy',
                pattern: '*.mapback_unmapped_counts.tsv',
                enabled: params.experimental == true
            ]
        ]
    }

    withName: 'SELECT_BLAST_QUERIES' {
        publishDir = [
            path: { params.target_query_preparation + "/blast_query_batches/contigs" },
            mode: 'copy',
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename },
            enabled: true
        ]
    }

    withName: 'NORMALIZE_READ_BLAST_QUERIES' {
        publishDir = [
            path: { params.target_query_preparation + "/blast_query_batches/read_queries" },
            mode: 'copy',
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename },
            enabled: params.experimental == true
        ]
    }

    withName: 'SUMMARIZE_BLAST_QUERY_BATCHES' {
        publishDir = [
            path: { params.target_query_preparation + "/decisions" },
            mode: 'copy',
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename },
            enabled: params.experimental == true
        ]
    }

    withName: 'SUMMARIZE_EMPTY_BLAST_QUERY_BATCHES' {
        publishDir = [
            path: { params.target_query_preparation + "/decisions" },
            mode: 'copy',
            enabled: params.experimental == true
        ]
    }

    // =========================================================================
    // 05 — Megablast hits (fast BLAST pass)
    // =========================================================================
    withName: 'ANNOTATE_MEGABLAST_RESULTS' {
        publishDir = [
            path: { params.megablast_hits + "/annotated" },
            mode: 'copy',
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename },
            enabled: true
        ]
    }

    withName: 'FILTER_NON_VIRUS_MEGABLAST_NODES' {
        publishDir = [
            [
                path: { params.megablast_hits + "/virus_only" },
                mode: 'copy',
                pattern: '*.txt',
                enabled: true
            ],
            [
                path: { params.megablast_hits + "/decisions" },
                mode: 'copy',
                pattern: '*.megablast_query_filtering.tsv',
                enabled: true
            ]
        ]
    }

    withName: 'PARTITION_MEGABLAST_QUERIES' {
        publishDir = [
            [
                path: { params.megablast_hits + "/query_partition" },
                mode: 'copy',
                pattern: '*.{txt,fasta}',
                enabled: true
            ],
            [
                path: { params.megablast_hits + "/decisions" },
                mode: 'copy',
                pattern: '*.megablast_query_partition.tsv',
                enabled: true
            ]
        ]
    }

    // =========================================================================
    // 06 — BLASTn hits (sensitive BLAST pass)
    // =========================================================================
    withName: 'ANNOTATE_BLASTN_RESULTS' {
        publishDir = [
            path: { params.blastn_hits + "/annotated" },
            mode: 'copy',
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename },
            enabled: true
        ]
    }

    withName: 'FILTER_NON_VIRUS_BLASTN_NODES' {
        publishDir = [
            [
                path: { params.blastn_hits + "/virus_only" },
                mode: 'copy',
                pattern: '*.txt',
                enabled: true
            ],
            [
                path: { params.blastn_hits + "/decisions" },
                mode: 'copy',
                pattern: '*.blastn_query_filtering.tsv',
                enabled: true
            ]
        ]
    }

    // =========================================================================
    // 07 — Merged BLAST results
    // =========================================================================
    withName: 'COMBINE_BATCH_SEARCH_HITS' {
        publishDir = [
            path: { params.merged_blast_results + "/combined_search_hits" },
            mode: 'copy',
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename },
            enabled: true
        ]
    }

    withName: 'ANNOTATE_LEAST_COMMON_ANCESTORS' {
        publishDir = [
            path: { params.merged_blast_results + "/lca_annotated/batches" },
            mode: 'copy',
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename },
            enabled: true
        ]
    }

    withName: 'STACK_BATCH_BLAST_RESULTS' {
        publishDir = [
            path: { params.merged_blast_results + "/lca_annotated/samples" },
            mode: 'copy',
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename },
            enabled: true
        ]
    }

    withName: 'ADD_READ_COUNTS_TO_BLAST' {
        publishDir = [
            path: { params.merged_blast_results + "/final" },
            mode: 'copy',
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename },
            enabled: true
        ]
    }

    withName: 'BUILD_QUERY_BIG_TABLE' {
        publishDir = [
            path: { params.big_tables + "/query/per_sample" },
            mode: 'copy',
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename },
            enabled: params.experimental == true
        ]
    }

    withName: 'BUILD_TAXON_BIG_TABLE' {
        publishDir = [
            path: { params.big_tables + "/taxon/per_sample" },
            mode: 'copy',
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename },
            enabled: params.experimental == true
        ]
    }

    // =========================================================================
    // Derived all-sample result tables
    // =========================================================================
    withName: 'CONCATENATE_EXPERIMENT_BLAST' {
        publishDir = [
            path: { params.experiment_summary },
            mode: 'copy',
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename },
            enabled: true
        ]
    }

    withName: 'BUILD_SEQUENCE_FLOW' {
        publishDir = [
            path: { params.experiment_summary },
            mode: 'copy',
            enabled: params.experimental == true
        ]
    }

    withName: 'CONCATENATE_QUERY_BIG_TABLE' {
        publishDir = [
            [
                path: { params.big_tables },
                mode: 'copy',
                saveAs: { filename -> filename.equals('versions.yml') ? null : filename },
                enabled: params.experimental == true
            ],
            [
                path: { params.nvd_results },
                mode: 'copy',
                saveAs: { filename -> filename.equals('versions.yml') ? null : filename },
                enabled: params.experimental == true
            ]
        ]
    }

    withName: 'CONCATENATE_TAXON_BIG_TABLE' {
        publishDir = [
            [
                path: { params.big_tables },
                mode: 'copy',
                saveAs: { filename -> filename.equals('versions.yml') ? null : filename },
                enabled: params.experimental == true
            ],
            [
                path: { params.nvd_results },
                mode: 'copy',
                saveAs: { filename -> filename.equals('versions.yml') ? null : filename },
                enabled: params.experimental == true
            ]
        ]
    }

    withName: 'TARGET_ENRICHMENT_REPORT' {
        publishDir = [
            [
                path: { params.target_enrichment_summaries },
                mode: 'copy',
                pattern: '*.tsv',
                enabled: !params.no_enrichment && (params.virus_index || params.virus_index_url || params.virus_reference_fasta)
            ],
            [
                path: { params.target_enrichment_plots },
                mode: 'copy',
                pattern: '*.{png,html}',
                enabled: !params.no_enrichment && (params.virus_index || params.virus_index_url || params.virus_reference_fasta)
            ]
        ]
    }

    // =========================================================================
    // 13 — LabKey uploads (only populated when labkey=true)
    // =========================================================================
    withName: 'LABKEY_PREPARE_BLAST' {
        publishDir = [
            path: { params.labkey_uploads + "/prepared_blast" },
            mode: 'copy',
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename },
            enabled: true
        ]
    }

    withName: 'LABKEY_PREPARE_FASTA' {
        publishDir = [
            path: { params.labkey_uploads + "/prepared_fasta" },
            mode: 'copy',
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename },
            enabled: true
        ]
    }

    withName: 'LABKEY_UPLOAD_BLAST' {
        publishDir = [
            path: { params.labkey_uploads + "/upload_logs" },
            mode: 'copy',
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename },
            enabled: true
        ]
    }

    withName: 'LABKEY_UPLOAD_FASTA' {
        publishDir = [
            path: { params.labkey_uploads + "/upload_logs" },
            mode: 'copy',
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename },
            enabled: true
        ]
    }

    withName: 'LABKEY_CONCAT_ALL_SAMPLE_BLAST_RESULTS' {
        publishDir = [
            path: { params.labkey_uploads + "/concatenated" },
            mode: 'copy',
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename },
            enabled: true
        ]
    }

    // =========================================================================
    // 08 — CRUMBS metagenomic profiles
    // =========================================================================
    withName: 'SUMMARIZE_CONTIG_COVERAGE' {
        publishDir = [
            path: { params.crumbs_profiles + "/profiling/coverage" },
            mode: 'copy',
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename },
            enabled: params.experimental == true
        ]
    }

    withName: 'COLLECT_CRUMBS_TAXIDS' {
        publishDir = [
            path: { params.crumbs_profiles + "/reference" },
            mode: 'copy',
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename },
            enabled: params.experimental == true
        ]
    }

    withName: 'PREPARE_NCBI_PROFILE_TAXONOMY' {
        publishDir = [
            path: { params.crumbs_profiles + "/reference" },
            mode: 'copy',
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename },
            enabled: params.experimental == true
        ]
    }

    withName: 'ESTIMATE_CRUMBS_PROFILE' {
        publishDir = [
            path: { params.crumbs_profiles + "/profiling" },
            mode: 'copy',
            saveAs: { filename ->
                if (filename.equals('versions.yml')) {
                    return null
                }
                if (filename.endsWith('.crumbs.queries.tsv')) {
                    return "queries/${filename}"
                }
                if (filename.endsWith('.crumbs.taxa.tsv')) {
                    return "taxa/${filename}"
                }
                if (filename.endsWith('.crumbs.bioboxes.profile.tsv')) {
                    return "bioboxes/${filename}"
                }
                if (filename.endsWith('.crumbs.qc.json')) {
                    return "qc/${filename}"
                }
                return filename
            },
            enabled: params.experimental == true
        ]
    }

    withName: 'EXPORT_CRUMBS_TAXONOMIC_REPORTS' {
        publishDir = [
            path: { params.crumbs_profiles + "/taxonomy" },
            mode: 'copy',
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename },
            enabled: params.experimental == true
        ]
    }

    withName: 'RENDER_CRUMBS_TAXBURST' {
        publishDir = [
            path: { params.crumbs_profiles + "/plots/taxburst/per_sample" },
            mode: 'copy',
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename },
            enabled: params.experimental == true
        ]
    }

    withName: 'RENDER_MERGED_CRUMBS_TAXBURST' {
        publishDir = [
            path: { params.crumbs_profiles + "/plots/taxburst" },
            mode: 'copy',
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename },
            enabled: params.experimental == true
        ]
    }

}
