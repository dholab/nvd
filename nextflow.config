params {

    // WORKFLOW PARAMETERS TO REVIEW AT EACH RUN
    // ----------------------------------------

    // Experimental feature gate. Keep disabled unless intentionally testing
    // release-candidate features that may change or be removed.
    experimental                             = false

    // LabKey integration
    // When enabled (--labkey), all labkey_* params below must be set.
    // Configure these in your user.config (~/.nvd/user.config) or via CLI.
    labkey                                  = false
    labkey_server                           = null
    labkey_project_name                     = null
    labkey_webdav                           = null
    labkey_schema                           = null
    labkey_blast_meta_hits_list             = null
    labkey_blast_fasta_list                 = null
    labkey_exp_id_guard_list                = null

    // Slack notifications for run completion
    // Requires SLACK_BOT_TOKEN secret configured via `nvd secrets`
    slack_enabled                           = false
    slack_channel                           = null

    // Explicit taxonomy directory. When null, the Python taxonomy preflight
    // resolves the runtime cache location from NVD_TAXONOMY_DB or the Python
    // config/local-data fallback rules; Nextflow does not read NVD_CONFIG_DIR.
    taxonomy_dir                            = null
    // Pipeline taxonomy mode. null preserves legacy NVD_TAXONOMY_OFFLINE
    // behavior; otherwise choose read_only or missing.
    taxonomy_mode                           = null
    // Admin refresh policy used by taxonomy preflight when taxonomy_mode is not
    // set: missing, stale, or force.
    taxonomy_refresh                        = "missing"
    taxonomy_max_age_days                   = 90

    // Samplesheet with the following columns:
    // sample_id,srr,platform,fastq1,fastq2
    samplesheet               = null
    // Where to place results
    results                   = "${launchDir}/results"

    // Experiment number to track
    experiment_id             = null

    max_concurrent_downloads  = 3

    // whether to empty the work directory after the workflow
    // successfully finishes
    cleanup                   = null

    // Nextflow work directory for intermediate files
    work_dir                  = "${launchDir}/work"

    blast_db_version          = "core-nt_2025-08-03"
    virus_index_version              = "v3.0"

    // Resource file paths on staging
    nvd_files                 = null
    blast_db                  = null
    blast_db_prefix           = null

    // Vertebrate-infecting virus enrichment with deacon. Enabled automatically
    // when any virus index source is provided; set no_enrichment to disable it.
    no_enrichment            = false
    virus_index               = null
    virus_index_url           = null
    virus_reference_fasta     = null
    virus_kmer_size           = 31
    virus_window_size         = 1
    virus_abs_threshold       = 1
    virus_rel_threshold       = 0.0

    // Experimental rapid k-mer screening, currently powered by sourmash. Disabled
    // by default; provide a local sketch, sketch URL, or local FASTA to opt in.
    // The go-to reference URL for NVD should for now be:
    // https://farm.cse.ucdavis.edu/~ctbrown/sourmash-db.new/ncbi-viruses-2025.01/ncbi-viruses-2025.01.dna.k=31.sig.zip
    // The go-to lineage CSV should be:
    // https://farm.cse.ucdavis.edu/~ctbrown/sourmash-db.new/ncbi-viruses-2025.01/ncbi-viruses.2025.01.lineages.csv
    sourmash_ref_path         = null
    sourmash_ref_url          = null
    sourmash_ref_fasta        = null
    sourmash_lineages_path    = null
    sourmash_lineages_url     = null
    sourmash_ksize            = 31
    sourmash_scaled           = 50
    sourmash_threshold_bp     = 50
    // whether to run all preprocessing of merged reads before classification
    preprocess                = false
    // whether to merge overlapping paired-end reads before downstream read QC
    merge_pairs               = false

    // Skip expensive downstream classification stages. null keeps direct
    // Nextflow flag usage ergonomic: `--skip_assembly` or `--skip_blast`.
    skip_assembly             = null
    skip_blast                = null

    // whether to deduplicate sequencing reads (umbrella: enables both dedup_seq and dedup_pos)
    dedup                     = false
    // sequence-based deduplication with clumpify (preprocessing)
    dedup_seq                 = false
    // positional deduplication with samtools markdup (after alignment)
    dedup_pos                 = false

    // Adapter trimming (Illumina only)
    trim_adapters             = null

    // Independently optional read quality/length and low-complexity filters
    filter_reads                = null
    filter_low_complexity_reads = false

    min_read_quality_illumina = 20
    min_read_quality_nanopore = 12
    min_read_length           = 50
    max_read_length           = null
    min_read_entropy          = 0.9

    // Optional host/contaminant depletion. Disabled by default; provide at
    // least one host index source to opt in.
    host_index                = null
    host_index_url            = null
    host_contaminants_fasta   = null
    host_kmer_size            = 31
    host_window_size          = 15
    host_abs_threshold        = 2
    host_rel_threshold        = 0.01

    // NVD settings
    cutoff_percent            = 0.001
    entropy                   = 0.9
    min_consecutive_bases     = 200
    qtrim                     = 't'
    tax_stringency            = 0.7
    include_children          = true
    human_virus_families      = [
        "Adenoviridae",
        "Anelloviridae",
        "Arenaviridae",
        "Arteriviridae",
        "Astroviridae",
        "Bornaviridae",
        "Peribunyaviridae",
        "Caliciviridae",
        "Coronaviridae",
        "Filoviridae",
        "Flaviviridae",
        "Hepadnaviridae",
        "Hepeviridae",
        "Orthoherpesviridae",
        "Orthomyxoviridae",
        "Papillomaviridae",
        "Paramyxoviridae",
        "Parvoviridae",
        "Picobirnaviridae",
        "Picornaviridae",
        "Pneumoviridae",
        "Polyomaviridae",
        "Poxviridae",
        "Sedoreoviridae",
        "Retroviridae",
        "Rhabdoviridae",
        "Togaviridae",
        "Kolmioviridae",
    ]

    // number of BLAST hits to consider before calling hits
    max_blast_targets         = 100

    // retain the top X many BLAST hits
    blast_retention_count     = 5


    // WORKFLOW PARAMETERS THAT SHOULD NOT BE CHANGED
    // ----------------------------------------
    date                      = null

    // directory for workflow resource files
    resources                 = "${projectDir}/resources"

    // Refman registry file
    refman_registry           = "${projectDir}/refman.toml"

    // mono-image filename or endpoint, if available
    monoimage                 = "nrminor/nvd:latest"

}

// Include the results publishing dirs from their separate file
includeConfig "${projectDir}/conf/results.config"

// WHETHER TO GENERATE A REPORT OF RUN STATISTICS
report {
    enabled   = true
    overwrite = true
    file      = "${params.results}/report.html"
}


// WHETHER TO GENERATE A VISUALIZATION OF THE WORKFLOW
dag {
    enabled   = true
    overwrite = true
    file      = 'workflow-visualization.png'
}


// WHETHER TO REMOVE TEMPORARY FILES AFTER A SUCCESSFUL RUN
cleanup = params.cleanup

// WORK DIRECTORY FOR INTERMEDIATE FILES
workDir = params.work_dir

// PROFILE OPTIONS
profiles {

    standard {

        apptainer.enabled = false
        docker.enabled    = false
        conda.enabled     = false
        process.executor  = 'local'
    }

    docker {

        docker.enabled    = true
        docker.temp       = 'auto'
        apptainer.enabled = false
        conda.enabled     = false

        process.container = "${params.monoimage}"
    }

    apptainer {

        apptainer.enabled    = true
        apptainer.cacheDir   = "work/apptainer/"
        apptainer.cacheDir   = "work/apptainer"
        apptainer.autoMounts = true
        docker.enabled       = false
        conda.enabled        = false

        process.container    = "docker://${params.monoimage}"
    }

    chtc_hpc {

        // container engine settings
        apptainer.enabled      = true
        apptainer.cacheDir     = "work/apptainer/"
        apptainer.cacheDir     = "work/apptainer"
        apptainer.autoMounts   = true

        // container address
        process.container      = "docker://${params.monoimage}"

        // slurm job settings
        process.executor       = "slurm"
        process.clusterOptions = "--partition=shared"
        process.maxForks       = 10
        process.cpus           = 20
        process.memory         = 64
        process.time           = 24.h
    }

    local {

        apptainer.enabled = false
        docker.enabled    = false
        conda.enabled     = false
        process.executor  = 'local'
    }

    test {

        apptainer.enabled               = false
        docker.enabled                  = false
        conda.enabled                   = false
        process.executor                = 'local'
        params.max_concurrent_downloads = 1
    }
}

// BLANKET PROCESS CONFIGURATIONS
process {
    errorStrategy = 'finish'

    withLabel: low {
        cpus   = 1
        memory = 4.GB
        disk   = 100.GB
    }

    withLabel: medium {
        cpus   = 6
        memory = 16.GB
        disk   = 200.GB
    }

    withLabel: high {
        cpus   = 20
        memory = 64.GB
        disk   = 300.GB
    }

    withName: 'SELECT_TOP_BLAST_HITS' {
        memory = 16.GB
    }

    withName: /SOURMASH_.*/ {
        // The experimental rapid-screening branch should not fail the whole run. If
        // these processes are reused outside the experimental gate, keep the
        // usual retry budget before ignoring the failure.
        errorStrategy = { params.experimental == true ? 'ignore' : (task.attempt < 3 ? 'retry' : 'ignore') }
        maxRetries    = 2
    }

    withName: /^(COMPUTE_SAMPLE_.*|REPORT_POSSIBLE_SAMPLE_MIXUPS|SUMMARIZE_SAMPLE_SIMILARITY|PLOT_SAMPLE_ORDINATION|RENDER_TAXON_ABUNDANCE_SUNBURST|RENDER_SOURMASH_SANKEY)$/ {
        // These reporting/QC processes are fed only by the experimental
        // rapid-screening branch, but optionality remains encoded in workflow channels.
        errorStrategy = { params.experimental == true ? 'ignore' : (task.attempt < 3 ? 'retry' : 'ignore') }
        maxRetries    = 2
    }
    
}

profiles {
    test {
        process {
            withLabel: low {
                cpus   = 1
                memory = 2.GB
            }

            withLabel: medium {
                cpus   = 2
                memory = 6.GB
            }

            withLabel: high {
                cpus   = 4
                memory = 8.GB
            }
        }
    }
}

// MANIFEST
manifest {
    homePage      = ''
    mainScript    = 'main.nf'
    defaultBranch = 'main'
    version       = '3.2.0'
    description   = ''
    author        = ''
}
